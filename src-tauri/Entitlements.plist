<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>keychain-access-groups</key>
	<!-- Team-ID prefix is hardcoded, not $(AppIdentifierPrefix): we codesign
	     directly (no Xcode / provisioning profile), and that macro is only
	     expanded by Xcode's build pipeline. Shipped unexpanded it is not a valid
	     team-prefixed group, so the DataProtection keychain rejects it with
	     errSecMissingEntitlement. V4YZPC7T6G is the Developer ID team; the app and
	     the conduit-gateway sidecar must both carry this exact group to share
	     keychain items with no prompts. -->
	<array>
		<string>V4YZPC7T6G.com.tsout.conduit</string>
	</array>
</dict>
</plist>
